# Copy to .env (never commit .env). All required unless noted.

WHAPI_TOKEN=          # Whapi channel token
FEATHERLESS_API_KEY=  # Featherless API key (featherless.ai)
MY_NUMBER=            # where flags go, digits only e.g. 4915123456789
WEBHOOK_SECRET=       # random string; also set as a custom header in the Whapi webhook config
DRY_RUN=true          # keep true until the voice + flagging are tuned
# ALLOWLIST=          # optional, comma-separated chat ids to restrict auto-handling

# --- only needed when running provision.py / deploy.py against Daytona ---
DAYTONA_API_KEY=
REPO_URL=https://github.com/hackathon-develop/2026-06-26_AIB_daytona
# SANDBOX_ID=         # printed by provision.py; store as a GitHub Actions secret
